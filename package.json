{
  "name": "neural-computer",
  "version": "0.1.0",
  "private": true,
  "description": "An LLM-driven runtime inspired by Zhuge et al.'s Neural Computers paper. Wraps JSON-UI (catalog-constrained renderer) and memoryjs (knowledge graph state) with a TypeScript orchestrator dispatching real computation to a Python subprocess.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@danielsimonjr/memoryjs": "^1.8.0",
    "@json-ui/core": "^0.1.0",
    "@json-ui/react": "^0.1.0",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.3",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18"
  }
}
