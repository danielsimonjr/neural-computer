{
  "name": "neural-computer",
  "version": "0.1.0",
  "private": true,
  "description": "An LLM-driven runtime inspired by Zhuge et al.'s Neural Computers paper. Wraps JSON-UI (catalog-constrained renderer) and memoryjs (knowledge graph state) with a TypeScript orchestrator dispatching real computation to a Python subprocess.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docs:deps": "npx tsx tools/create-dependency-graph/create-dependency-graph.ts --include-tests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@danielsimonjr/memoryjs": "file:../memoryjs",
    "@json-ui/core": "file:../JSON-UI/packages/core",
    "@json-ui/react": "file:../JSON-UI/packages/react",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.3",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18"
  }
}
